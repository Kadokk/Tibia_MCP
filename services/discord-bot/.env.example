DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DATABASE_URL=postgres://tibiaedge:***@localhost:5432/tibiaedge
# Docker Compose only: password for the bundled Postgres. Compose reads this from the
# repo-root .env to build both the db container and the bot's DATABASE_URL override.
POSTGRES_PASSWORD=
NODE_ENV=development
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
MCP_SERVER_COMMAND=/app/bin/tibia-mcp
MCP_SERVER_CWD=/app/data
AI_DAILY_SPEND_CAP_USD=0.7
TIBIADATA_BASE_URL=https://api.tibiadata.com
