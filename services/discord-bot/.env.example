DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
DATABASE_URL=postgres://tibiaedge:***@localhost:5432/tibiaedge
# Docker Compose only: password for the bundled Postgres. Compose reads this from the
# repo-root .env to build both the db container and the bot's DATABASE_URL override.
POSTGRES_PASSWORD=
NODE_ENV=development
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5
# Under Docker, DO NOT set MCP_SERVER_COMMAND: env_file overrides the image ENV,
# and the image's default (/app/bin/tibia-mcp-impersonate) carries the
# curl-impersonate wrapper that defeats tibia.com's TLS-fingerprint 403.
# Setting the plain binary path here silently re-breaks bazaar tools.
# Only set it for non-Docker local runs (point it at your built binary).
# MCP_SERVER_COMMAND=
MCP_SERVER_CWD=/app/data
AI_DAILY_SPEND_CAP_USD=0.7
TIBIADATA_BASE_URL=https://api.tibiadata.com
