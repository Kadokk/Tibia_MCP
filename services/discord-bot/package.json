{
  "name": "@tibiaedge/discord-bot",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx src/main.ts",
    "test": "vitest",
    "typecheck": "tsc --noEmit -p tsconfig.check.json",
    "lint": "eslint src",
    "build": "tsc -p tsconfig.json",
    "eval": "tsx eval/run.ts",
    "eval:distill": "tsx eval/distill.ts",
    "import:quests": "tsx src/importers/runQuestImport.ts",
    "import:catalog": "tsx src/importers/runCatalogImport.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "discord.js": "^14.16.3",
    "dotenv": "^16.4.7",
    "openai": "^6.48.0",
    "pg": "^8.13.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "@types/pg": "^8.11.10",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
