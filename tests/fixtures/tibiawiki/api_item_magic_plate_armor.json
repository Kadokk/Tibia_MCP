{"parse":{"title":"Magic Plate Armor","pageid":2303,"redirects":[],"text":{"*":"<div class=\"mw-content-ltr mw-parser-output\" lang=\"en\" dir=\"ltr\"><div class=\"twbox\">\n<p class=\"mw-empty-elt\">\n</p><aside role=\"region\" class=\"portable-infobox pi-background pi-border-color pi-theme-twbox pi-layout-default\">\n<h2 class=\"pi-item pi-item-spacing pi-title pi-secondary-background\" data-source=\"name\">Magic Plate Armor</h2>\n\n<figure class=\"pi-item pi-image\">\n\t<a href=\"https://static.wikia.nocookie.net/tibia/images/3/31/Magic_Plate_Armor.gif/revision/latest?cb=20050601145437&amp;path-prefix=en\" class=\"image image-thumbnail\" title=\"Magic Plate Armor\">\n\t\t<img src=\"https://static.wikia.nocookie.net/tibia/images/3/31/Magic_Plate_Armor.gif/revision/latest?cb=20050601145437&amp;path-prefix=en\" srcset=\"https://static.wikia.nocookie.net/tibia/images/3/31/Magic_Plate_Armor.gif/revision/latest?cb=20050601145437&amp;path-prefix=en 1x, https://static.wikia.nocookie.net/tibia/images/3/31/Magic_Plate_Armor.gif/revision/latest?cb=20050601145437&amp;path-prefix=en 2x\" class=\"pi-image-thumbnail\" data-relevant=\"1\" alt=\"Magic Plate Armor\" width=\"32\" height=\"32\" data-image-key=\"Magic_Plate_Armor.gif\" data-image-name=\"Magic Plate Armor.gif\" />\n\t\t\n\t</a>\n\t\n</figure>\n<section class=\"pi-item pi-group pi-border-color\">\n\t<h2 class=\"pi-item pi-header pi-secondary-font pi-item-spacing pi-secondary-background\">Requirements</h2>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"vocrequired\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Vocation</h3>\n\t\n\t<div class=\"pi-data-value pi-font\">knights and paladins</div>\n</div>\n\n</section>\n<section class=\"pi-item pi-group pi-border-color\">\n\t<h2 class=\"pi-item pi-header pi-secondary-font pi-item-spacing pi-secondary-background\">Combat Properties</h2>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"imbueslots\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Imbuing Slots</h3>\n\t\n\t<div class=\"pi-data-value pi-font\">2</div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"upgradeclass\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Upgrade Classification</h3>\n\t\n\t<div class=\"pi-data-value pi-font\">2</div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"armor\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Armor</h3>\n\t\n\t<div class=\"pi-data-value pi-font\">17</div>\n</div>\n\n</section>\n<section class=\"pi-item pi-group pi-border-color\">\n\t<h2 class=\"pi-item pi-header pi-secondary-font pi-item-spacing pi-secondary-background\">General Properties</h2>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"objectclass\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Classification</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><a href=\"/wiki/Body_Equipment\" class=\"mw-redirect\" title=\"Body Equipment\">Body Equipment</a><br /><a href=\"/wiki/Armors\" title=\"Armors\">Armors</a></div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"pickupable\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Pickupable</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><span class=\"yes-tick\" title=\"Yes\">&#10003;</span></div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"weight\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Weight</h3>\n\t\n\t<div class=\"pi-data-value pi-font\">85.00 oz</div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"stackable\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Stackable</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><span class=\"no-cross\" title=\"No\">&#10007;</span></div>\n</div>\n\n</section>\n<section class=\"pi-item pi-group pi-border-color\">\n\t<h2 class=\"pi-item pi-header pi-secondary-font pi-item-spacing pi-secondary-background\">Trade Properties</h2>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"marketable\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Marketable</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><span class=\"yes-tick\" title=\"Yes\">&#10003;</span></div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"value\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Value</h3>\n\t\n\t<div class=\"pi-data-value pi-font\">90,000 - 150,000 gp</div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"npcvalue\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Sold for</h3>\n\t\n\t<div class=\"pi-data-value pi-font\">90,000 gp</div>\n</div>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"npcprice\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Bought for</h3>\n\t\n\t<div class=\"pi-data-value pi-font\">(not sold by NPCs)</div>\n</div>\n\n</section>\n<section class=\"pi-item pi-group pi-border-color\">\n\t<h2 class=\"pi-item pi-header pi-secondary-font pi-item-spacing pi-secondary-background\">Field Properties</h2>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"walkable\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Blocking</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><span class=\"no-cross\" title=\"No\">&#10007;</span></div>\n</div>\n\n</section>\n<section class=\"pi-item pi-group pi-border-color\">\n\t<h2 class=\"pi-item pi-header pi-secondary-font pi-item-spacing pi-secondary-background\">Other Properties</h2>\n\n<div class=\"pi-item pi-data pi-item-spacing pi-border-color\" data-source=\"implemented\">\n\t\n\t\t<h3 class=\"pi-data-label pi-secondary-font\">Version</h3>\n\t\n\t<div class=\"pi-data-value pi-font\"><a href=\"/wiki/Updates/3.0\" title=\"Updates/3.0\">3.0</a><br /><span class=\"implementation-date\">October 28, 1997<br />Alpha 3.0</span></div>\n</div>\n\n</section>\n<nav class=\"pi-navigation pi-item-spacing pi-secondary-font\">See also: <a href=\"/wiki/Objects\" title=\"Objects\">Objects</a><span class=\"explained\"><a href=\"/wiki/Template:Infobox_Object#Usage\" title=\"Template:Infobox Object\">Help</a></span></nav>\n</aside>\n\n<p class=\"mw-empty-elt\"></p>\n    <div id=\"twbox-intro\">\n        <div id=\"object-profile\">\n        \t<div data-object-image=\"https&#58;//static.wikia.nocookie.net/tibia/images/3/31/Magic&#95;Plate&#95;Armor.gif/revision/latest?cb=20050601145437&amp;path-prefix=en&amp;format=original\"></div>\n            <div id=\"twbox-image\"><img src=\"https://static.wikia.nocookie.net/tibia/images/3/31/Magic_Plate_Armor.gif/revision/latest?cb=20050601145437&amp;path-prefix=en&amp;format=original\" alt=\"latest?cb=20050601145437&amp;path-prefix=en&amp;format=original\" /></div>\n            <div id=\"twbox-look\"><div class=\"item-look tibiatext tibiagreen\">You see a magic plate armor&#32;<span class=\"p-attributes\">(Arm:17)</span>.<br />Imbuements: (Empty Slot, Empty Slot).<br />Classification: 2 Tier: 0.<div class=\"p-reqs\">It can only be wielded properly by&#32;knights and paladins.<br /></div><div class=\"p-weight\">It weighs 85.00 oz.</div><br /></div></div>\n            <div id=\"twbox-sounds\" class=\"\"><span class=\"tibiatext tibiaorange\"><ul class=\"sound-list\"></ul></span></div>\n        </div>\n    </div>\n    <div style=\"clear:left;\"></div>\n    <div id=\"object-notes\">\n        <h3><span class=\"mw-headline\" id=\"Notes\">Notes</span></h3>\n<p>It is also known as \"MPA\" or \"e-plate\" (Enchanted Plate Armor).\n</p>\n    </div>\n    <div style=\"clear:left;\"></div>\n    <div id=\"object-history\" class=\"history-section\">\n        <h3><span class=\"mw-headline\" id=\"History\">History</span></h3>\n<ul><li>Its armor value was changed from 18 to 17 with <a href=\"/wiki/Updates/7.0\" title=\"Updates/7.0\">Update 7.0</a>.</li>\n<li>After <a href=\"/wiki/Updates/8.4\" class=\"mw-redirect\" title=\"Updates/8.4\">Christmas Update 2008</a>, this armor became restricted to <a href=\"/wiki/Knight\" title=\"Knight\">knights</a> and <a href=\"/wiki/Paladin\" title=\"Paladin\">paladins</a>.</li></ul>\n    </div>\n    <div style=\"clear:left;\"></div>\n    <div id=\"item-droppedby\">\n    \t<h3><span class=\"mw-headline\" id=\"Dropped_By\">Dropped By</span></h3>\n    \t<div class=\"item-droppedby-wrapper\">\n<ul><li><a href=\"/wiki/Angry_Demon\" title=\"Angry Demon\">Angry Demon</a></li>\n<li><a href=\"/wiki/Demon\" title=\"Demon\">Demon</a></li>\n<li><a href=\"/wiki/Dracola\" title=\"Dracola\">Dracola</a></li>\n<li><a href=\"/wiki/Ferumbras\" title=\"Ferumbras\">Ferumbras</a></li>\n<li><a href=\"/wiki/Ferumbras_Mortal_Shell\" title=\"Ferumbras Mortal Shell\">Ferumbras Mortal Shell</a></li>\n<li><a href=\"/wiki/Ghazbaran\" title=\"Ghazbaran\">Ghazbaran</a></li>\n<li><a href=\"/wiki/Grimeleech\" title=\"Grimeleech\">Grimeleech</a></li>\n<li><a href=\"/wiki/Harpy\" title=\"Harpy\">Harpy</a></li>\n<li><a href=\"/wiki/Hellflayer\" title=\"Hellflayer\">Hellflayer</a></li>\n<li><a href=\"/wiki/Katex_Blood_Tongue\" title=\"Katex Blood Tongue\">Katex Blood Tongue</a></li>\n<li><a href=\"/wiki/Morgaroth\" title=\"Morgaroth\">Morgaroth</a></li>\n<li><a href=\"/wiki/Orshabaal\" title=\"Orshabaal\">Orshabaal</a></li>\n<li><a href=\"/wiki/Rage_Squid\" title=\"Rage Squid\">Rage Squid</a></li>\n<li><a href=\"/wiki/Sight_of_Surrender\" title=\"Sight of Surrender\">Sight of Surrender</a></li>\n<li><a href=\"/wiki/Terofar\" title=\"Terofar\">Terofar</a></li>\n<li><a href=\"/wiki/Utua_Stone_Sting\" title=\"Utua Stone Sting\">Utua Stone Sting</a></li>\n<li><a href=\"/wiki/Vexclaw\" title=\"Vexclaw\">Vexclaw</a></li>\n<li><a href=\"/wiki/Yirkas_Blue_Scales\" title=\"Yirkas Blue Scales\">Yirkas Blue Scales</a></li></ul>\n    <div style=\"clear:left;\"></div>\n    </di